# save/restore stats
record(calc, "$(S):Chop:Skf:SR_status")
{
    field(DESC, "SKF chop sav/rst stat sum")
    field(INPA, "$(S):SavRst:ChopSkf1:SR_status CP MS")
    field(INPB, "$(S):SavRst:ChopSkf2:SR_status CP MS")
    field(INPC, "$(S):SavRst:ChopSkf3:SR_status CP MS")
    field(INPD, "$(S):SavRst:ChopSkf4:SR_status CP MS")
    field(INPE, "$(S):SavRst:ChopSkf5:SR_status CP MS")
    field(INPF, "$(S):SavRst:ChopSkf6:SR_status CP MS")
    field(INPG, "$(S):SavRst:ChopSkfCalc1:SR_status CP MS")
    field(INPH, "$(S):SavRst:ChopSkfCalc2:SR_status CP MS")
    field(INPI, "$(S):SavRst:ChopSkfCalc3:SR_status CP MS")
    field(CALC, "MIN(A,B,C,D,E,F,G,H,I)")
    field(LOLO, "3")
    field(LLSV, "MAJOR")
}

# Not phase locked
record(calc, "$(S):Chop:Skf:PhaseLockedSummary")
{
    field(DESC, "Phase locked summary")
    field(INPA, "$(S):Chop:Skf1:PhaseLocked CP MS")
    field(INPB, "$(S):Chop:Skf2:PhaseLocked CP MS")
    field(INPC, "$(S):Chop:Skf3:PhaseLocked CP MS")
    field(INPD, "$(S):Chop:Skf4:PhaseLocked CP MS")
    field(INPE, "$(S):Chop:Skf5:PhaseLocked CP MS")
    field(INPF, "$(S):Chop:Skf5:PhaseLocked CP MS")
    field(CALC, "A&&B&&C&&D&&E&&F")
}
