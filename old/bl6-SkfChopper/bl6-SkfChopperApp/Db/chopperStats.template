# Chopper Status, summary PVs
#
# All logic tries to use 1 = OK, 0 = Not OK,
# adopting whatever the inputs provide
#
# All these PVs use non-zero = error, zero = OK
#
# {S} must be defined in substitution file
#

# SKF Choppers

# ioc stats
record(calc, "$(S):IocSts:ChopSkf:STATUS")
{
    field(DESC, "SKF chopper status summary")
    field(INPA, "$(S):IocSts:ChopSkf1:STATUS CP MS")
    field(INPB, "$(S):IocSts:ChopSkf2:STATUS CP MS")
    field(INPC, "$(S):IocSts:ChopSkf3:STATUS CP MS")
    field(INPD, "$(S):IocSts:ChopSkf4:STATUS CP MS")
    field(INPE, "$(S):IocSts:ChopSkf5:STATUS CP MS")
    field(INPF, "$(S):IocSts:ChopSkf6:STATUS CP MS")
    field(INPG, "$(S):IocSts:ChopSkfCalc1:STATUS CP MS")
    field(INPH, "$(S):IocSts:ChopSkfCalc2:STATUS CP MS")
    field(INPI, "$(S):IocSts:ChopSkfCalc3:STATUS CP MS")
    field(CALC, "A||B||C||D||E||F||G||H||I")
    field(HIHI, "0.5")
    field(HHSV, "MAJOR")
}

# Errors
record(calc, "$(S):CS:ChopSkf:STATUS")
{
    field(DESC, "SKF chopper status summary")
    field(INPA, "$(S):Chop:Skf:DriveError:STATUS CP MS")
    field(INPB, "$(S):Chop:Skf:RefLoss:STATUS CP MS")
    field(INPC, "$(S):Chop:Skf1:MotorSpeed CP MS")
    field(INPD, "$(S):Chop:Skf2:MotorSpeed CP MS")
    field(INPE, "$(S):Chop:Skf3:MotorSpeed CP MS")
    field(INPF, "$(S):Chop:Skf4:MotorSpeed CP MS")
    field(INPG, "$(S):Chop:Skf5:MotorSpeed CP MS")
    field(INPH, "$(S):Chop:Skf6:MotorSpeed CP MS")
    field(CALC, "A||B||MIN(C,D,E,F,G,H)<2.0")
    field(HIHI, "0.5")
    field(HHSV, "MAJOR")
    alias("$(S):Chop:Skf:STATUS")
}

