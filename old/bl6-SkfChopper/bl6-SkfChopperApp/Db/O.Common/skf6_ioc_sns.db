##########################################################
# Extra SNS records

# ///
# /// Add a new record to calculate
# /// percent memory and file descriptors used.
# /// Then forward link to some new status records below.
# ///
record(calc, "BL6:IocSts:ChopSkf6:MEM_USED_PER") {
  field(SCAN, "1 second")
  field(INPA, "BL6:IocSts:ChopSkf6:MEM_USED")
  field(INPB, "BL6:IocSts:ChopSkf6:MEM_MAX")
  field(CALC, "(A/B)*100")
  field(EGU, "%")
  field(PREC, "2")
  field(HIGH, "50")
  field(HIHI, "80")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  field(FLNK, "BL6:IocSts:ChopSkf6:FD_CNT_PER")
  info(autosaveFields_pass0, "HIGH HIHI")
}
record(calc, "BL6:IocSts:ChopSkf6:FD_CNT_PER") {
  field(INPA, "BL6:IocSts:ChopSkf6:FD_CNT")
  field(INPB, "BL6:IocSts:ChopSkf6:FD_MAX")
  field(CALC, "(A/B)*100")
  field(EGU, "%")
  field(PREC, "1")
  field(HIGH, "80")
  field(HIHI, "90")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  field(FLNK, "BL6:IocSts:ChopSkf6:Q_SEVR")
  info(autosaveFields_pass0, "HIGH HIHI")
}

# ///
# /// Add limits on the queue used % records
# ///
record(calc, "BL6:IocSts:ChopSkf6:SCANONCE_Q_USEDPER") {
  field(PREC, "1")
  field(HIGH, "50")
  field(HIHI, "80")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  info(autosaveFields_pass0, "HIGH HIHI")
}
record(calc, "BL6:IocSts:ChopSkf6:CBLOW_Q_USEDPER") {
  field(PREC, "1")
  field(HIGH, "50")
  field(HIHI, "80")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  info(autosaveFields_pass0, "HIGH HIHI")
}
record(calc, "BL6:IocSts:ChopSkf6:CBMEDIUM_Q_USEDPER") {
  field(PREC, "1")
  field(HIGH, "50")
  field(HIHI, "80")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  info(autosaveFields_pass0, "HIGH HIHI")
}
record(calc, "BL6:IocSts:ChopSkf6:CBHIGH_Q_USEDPER") {
  field(PREC, "1")
  field(HIGH, "50")
  field(HIHI, "80")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  info(autosaveFields_pass0, "HIGH HIHI")
}

# ///
# /// Add limits on the queue high % records
# ///
record(calc, "BL6:IocSts:ChopSkf6:SCANONCE_Q_HIGHPER") {
  field(PREC, "1")
  field(HIGH, "50")
  field(HIHI, "80")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  info(autosaveFields_pass0, "HIGH HIHI")
}
record(calc, "BL6:IocSts:ChopSkf6:CBLOW_Q_HIGHPER") {
  field(PREC, "1")
  field(HIGH, "50")
  field(HIHI, "80")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  info(autosaveFields_pass0, "HIGH HIHI")
}
record(calc, "BL6:IocSts:ChopSkf6:CBMEDIUM_Q_HIGHPER") {
  field(PREC, "1")
  field(HIGH, "50")
  field(HIHI, "80")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  info(autosaveFields_pass0, "HIGH HIHI")
}
