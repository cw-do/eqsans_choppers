  field(HIGH, "50")
  field(HIHI, "80")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  info(autosaveFields_pass0, "HIGH HIHI")
}

# ///
# /// Add limits on the queue overrun records
# ///
record(ai, "BL6:IocSts:ChopSkf6:SCANONCE_Q_OVERRUNS") {
  field(HIGH, "1")
  field(HIHI, "1")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  info(autosaveFields_pass0, "HIGH HIHI")
}
record(ai, "BL6:IocSts:ChopSkf6:CBLOW_Q_OVERRUNS") {
  field(HIGH, "1")
  field(HIHI, "1")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  info(autosaveFields_pass0, "HIGH HIHI")
}
record(ai, "BL6:IocSts:ChopSkf6:CBMEDIUM_Q_OVERRUNS") {
  field(HIGH, "1")
  field(HIHI, "1")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  info(autosaveFields_pass0, "HIGH HIHI")
}
record(ai, "BL6:IocSts:ChopSkf6:CBHIGH_Q_OVERRUNS") {
  field(HIGH, "1")
  field(HIHI, "1")
  field(HSV, "MINOR")
  field(HHSV, "MAJOR")
  info(autosaveFields_pass0, "HIGH HIHI")
}

# ///
# /// Summarize the Q severity
# ///
record(calc, "BL6:IocSts:ChopSkf6:Q_SEVR") {
  field(INPA, "BL6:IocSts:ChopSkf6:SCANONCE_Q_USEDPER MS")
  field(INPB, "BL6:IocSts:ChopSkf6:CBLOW_Q_USEDPER MS")
  field(INPC, "BL6:IocSts:ChopSkf6:CBMEDIUM_Q_USEDPER MS")
  field(INPD, "BL6:IocSts:ChopSkf6:CBHIGH_Q_USEDPER MS")
  field(INPE, "BL6:IocSts:ChopSkf6:SCANONCE_Q_HIGHPER MS")
  field(INPF, "BL6:IocSts:ChopSkf6:CBLOW_Q_HIGHPER MS")
  field(INPG, "BL6:IocSts:ChopSkf6:CBMEDIUM_Q_HIGHPER MS")
  field(INPH, "BL6:IocSts:ChopSkf6:CBHIGH_Q_HIGHPER MS")
  field(INPI, "BL6:IocSts:ChopSkf6:SCANONCE_Q_OVERRUNS MS")
  field(INPJ, "BL6:IocSts:ChopSkf6:CBLOW_Q_OVERRUNS MS")
  field(INPK, "BL6:IocSts:ChopSkf6:CBMEDIUM_Q_OVERRUNS MS")
  field(INPL, "BL6:IocSts:ChopSkf6:CBHIGH_Q_OVERRUNS MS")
  field(FLNK, "BL6:IocSts:ChopSkf6:STATCALC")
}

# ///
# /// Top level status record
# ///
record(calcout, "BL6:IocSts:ChopSkf6:STATCALC") {
  field(DESC, "IOC Stat Status Calc")
  field(INPA, "BL6:IocSts:ChopSkf6:STATCTRL")
  field(INPB, "BL6:IocSts:ChopSkf6:SYS_CPU_LOAD.SEVR")
  field(INPC, "BL6:IocSts:ChopSkf6:IOC_CPU_LOAD.SEVR")
  field(INPD, "BL6:IocSts:ChopSkf6:CA_CLNT_CNT.SEVR")
  field(INPE, "BL6:IocSts:ChopSkf6:CA_CONN_CNT.SEVR")
  field(INPF, "BL6:IocSts:ChopSkf6:SUSP_TASK_CNT.SEVR")
  field(INPG, "BL6:IocSts:ChopSkf6:SCANMON_SEVR.SEVR")
  field(INPH, "BL6:IocSts:ChopSkf6:Q_SEVR.SEVR")
  field(INPI, "BL6:IocSts:ChopSkf6:MEM_USED_PER.SEVR")
  field(INPJ, "BL6:IocSts:ChopSkf6:FD_CNT_PER.SEVR")
  field(CALC, "A?0:(B>1||C>1||D>1||E>1||F>1||G>1||H>1||I>1||J>1)")
  field(OOPT, "Every Time")
  field(OUT, "BL6:IocSts:ChopSkf6:STATUS PP")
}
record(bo, "BL6:IocSts:ChopSkf6:STATUS") {
  field(DESC, "IOC Stat Status")
  field(ZNAM, "IOC Status OK")
  field(ONAM, "IOC Status Problem")
  field(ZSV, "NO_ALARM")
  field(OSV, "MAJOR")
  info(archive, "Monitor, 00:00:01, VAL")
}
record(bo, "BL6:IocSts:ChopSkf6:STATCTRL") {
  field(DESC, "IOC Stat Control")
  field(PINI, "YES")
  field(VAL, "0")
  field(ZNAM, "Alarm Enabled")
  field(ONAM, "Alarm Disabled")
  field(ZSV, "NO_ALARM")
  field(OSV, "MINOR")
  field(FLNK, "BL6:IocSts:ChopSkf6:STATCALC")
  info(autosaveFields_pass0, "VAL")
  info(archive, "Monitor, 00:00:01, VAL")
}
