#####################################################
# for scan server helper
#Rewrote for 6 choppers by Bhargavi Krishna on 2/13/26
#
# This is for treating all six choppers at EQSANS as a single 6-disk chopper,
# which seems to be a reasonable match for the legacy software there. 

# The choppers are assumed to be named Skf[1-6]; they are not macroized. The
# plan is that they will be controlled in totalDelay mode. The hexaDskChopper
# will be controlled by initial wavelength.
#
# Not sure what the hexa will be called so leaving hexa macro in place.

record(stringout, "$(s):$(ta):$(hexa):QdDiskVer") {
  field(VAL, "1-2-0")
}

record(longout, "$(s):$(ta):Skf$(hexa):HelperState") {
  field(SCAN, "Passive")
}

record(bo, "$(s):$(ta):Skf$(hexa):CmdError") {
  field(ZNAM, "0")
  field(ONAM, "1")
  field(SCAN, "Passive")
}

################
#
# Reset request
#

record(bo, "$(s):$(ta):Skf$(hexa):SyncScanPvsReq") {
  field(ZNAM, "0")
  field(ONAM, "1")
  field(SCAN, "Passive")
  field(FLNK, "$(s):$(ta):Skf$(hexa):SyncScanPvsReqComplete PP")
}

record(bo, "$(s):$(ta):Skf$(hexa):SyncScanPvsReqComplete") {
  field(ZNAM, "0")
  field(ONAM, "1")
  field(SCAN, "Passive")
  field(VAL, "1")
  field(OUT, "$(s):$(ta):Skf$(hexa):SyncScanPvsReqBusy PP")
}

record(busy, "$(s):$(ta):Skf$(hexa):SyncScanPvsReqBusy") {
  field(SCAN, "Passive")
}

################

record(ao, "$(s):$(ta):Skf$(hexa):DistModSamp") {
   field(EGU, "m")
   info(autosaveFields, "VAL")
   info(archive, "Monitor,00:00:10,VAL")
}

# set all our chopper modes. defaults to total delay.

record(dfanout, "$(s):$(ta):Skf$(hexa):PhaseEntryModeSet")
{
  field(DOL,  "3")
  field(OUTA, "$(s):$(ta):Skf1:PhaseEntryMode PP")
  field(OUTB, "$(s):$(ta):Skf2:PhaseEntryMode PP")
  field(OUTC, "$(s):$(ta):Skf3:PhaseEntryMode PP")
  field(OUTD, "$(s):$(ta):Skf4:PhaseEntryMode PP")
  field(OUTE, "$(s):$(ta):Skf5:PhaseEntryMode PP")
  field(OUTF, "$(s):$(ta):Skf6:PhaseEntryMode PP")
}

################

record(ao, "$(s):$(ta):Skf$(hexa):InitWvlenReq") {
  field(EGU, "A")
  field(SCAN, "Passive")
  field(MDEL, "-1")
  info(autosaveFields, "VAL")
  field(FLNK, "$(s):$(ta):Skf$(hexa):InitWvlenReqBo PP")
}

record(bo, "$(s):$(ta):Skf$(hexa):InitWvlenReqBo") {
  field(ZNAM, "0")
  field(ONAM, "1")
  field(SCAN, "Passive")
  field(VAL, "1")
  field(OUT, "$(s):$(ta):Skf$(hexa):InitWvlenReqBusy PP")
}

record(busy, "$(s):$(ta):Skf$(hexa):InitWvlenReqBusy") {
  field(SCAN, "Passive")
}

#############################
#While InitWvlenReq is used as minimum wavlength in Monochromatic mode, 
#MCMaxWvlenReq is created for momochromatic mode max wavelength

record(bo, "$(s):$(ta):Skf$(hexa):MCON") {
  field(ZNAM, "0")
  field(ONAM, "1")
  field(SCAN, "Passive")
}

record(ao, "$(s):$(ta):Skf$(hexa):MCMaxWvlenReq") {
  field(EGU, "A")
  field(SCAN, "Passive")
  field(MDEL, "-1")
  info(autosaveFields, "VAL")
  field(FLNK, "$(s):$(ta):Skf$(hexa):MCMaxWvlenReqBo PP")
}

