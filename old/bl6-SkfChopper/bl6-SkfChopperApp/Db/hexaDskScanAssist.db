# just ask to reprocess the phase.  do this after the stage is moved.
record(ao, "$(s):$(ta):Skf$(hexa):ProcDistReq") {
  field(EGU, "m")
  field(SCAN, "Passive")
  field(MDEL, "-1")
  info(autosaveFields, "VAL")
  field(FLNK, "$(s):$(ta):Skf$(hexa):ProcDistReqBo PP")
}

