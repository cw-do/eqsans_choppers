##########################################################
# One Pv to control all speeds
#
record(bo, "$(s):$(ta):Skf$(hexa):SpeedEnum") {
  field(ZNAM, "30 Hz")
  field(ONAM, "60 Hz")
  field(FLNK, "$(s):$(ta):Skf$(hexa):SpeedCalc")
  info(autosaveFields, "VAL")
}

record(calcout, "$(s):$(ta):Skf$(hexa):SpeedCalc") {
  field(INPA, "$(s):$(ta):Skf$(hexa):SpeedEnum")
  field(CALC, "A?60.0:30.0")
  field(OUT, "$(s):$(ta):Skf$(hexa):SpeedReq PP")
}

record(ao, "$(s):$(ta):Skf$(hexa):SpeedReq") {
  field(EGU, "A")
  info(autosaveFields, "VAL")
  field(FLNK, "$(s):$(ta):Skf$(hexa):SpeedSSeq")
}

record(sseq, "$(s):$(ta):Skf$(hexa):SpeedSSeq")
{
  field(DOL1, "$(s):$(ta):Skf$(hexa):SpeedReq")
  field(WAIT1, "After6")
  field(LNK1, "$(s):$(ta):Skf1:SpeedReq CA")

  field(DOL2, "$(s):$(ta):Skf$(hexa):SpeedReq")
  field(WAIT2, "After6")
  field(LNK2, "$(s):$(ta):Skf2:SpeedReq CA")

  field(DOL3, "$(s):$(ta):Skf$(hexa):SpeedReq")
  field(WAIT3, "After6")
  field(LNK3, "$(s):$(ta):Skf3:SpeedReq CA")

  field(DOL4, "$(s):$(ta):Skf$(hexa):SpeedReq")
  field(WAIT4, "After6")
  field(LNK4, "$(s):$(ta):Skf4:SpeedReq CA")
  field(DOL5, "$(s):$(ta):Skf$(hexa):SpeedReq")
  field(WAIT5, "After6")
  field(LNK5, "$(s):$(ta):Skf5:SpeedReq CA")
  field(DOL6, "$(s):$(ta):Skf$(hexa):SpeedReq")
  field(WAIT6, "Wait")
  field(LNK6, "$(s):$(ta):Skf6:SpeedReq CA")

  field(FLNK, "$(s):$(ta):Skf$(hexa):SpeedReqRBV")
}

record(calc, "$(s):$(ta):Skf$(hexa):SpeedReqRBV") {
  field(INPA, "$(s):$(ta):Skf1:SpeedReq")
  field(INPB, "$(s):$(ta):Skf2:SpeedReq")
  field(INPC, "$(s):$(ta):Skf3:SpeedReq")
  field(INPD, "$(s):$(ta):Skf4:SpeedReq")
  field(INPE, "$(s):$(ta):Skf5:SpeedReq")
  field(INPF, "$(s):$(ta):Skf6:SpeedReq")
  field(CALC, "min(A,B,C,D,E,F)")
} 

record(calcout, "$(s):$(ta):Skf$(hexa):Busy") {
  field(INPA,"$(s):$(ta):Skf$(hexa):SpeedSSeq.BUSY CP MS")
  field(CALC,"(A=1)?1:0")
  field(OOPT, "Every Time")
  field(DOPT, "Use CALC")
  field(OUT, "$(s):$(ta):Skf$(hexa):SpeedReqBusy PP")
}

record(bi, "$(s):$(ta):Skf$(hexa):SpeedReqBusy")
{
    field(ZNAM, "Idle")
    field(ONAM, "Running")
    field(OSV,  "MINOR")
    info(archive, "Monitor, 00:00:01, VAL")
}

