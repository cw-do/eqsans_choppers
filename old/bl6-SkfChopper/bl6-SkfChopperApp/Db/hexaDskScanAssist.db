  field(ONAM, "1")
  field(SCAN, "Passive")
  field(VAL, "1")
  field(OUT, "$(s):$(ta):Skf$(hexa):MCMaxWvlenReqBusy PP")
}

record(busy, "$(s):$(ta):Skf$(hexa):MCMaxWvlenReqBusy") {
  field(SCAN, "Passive")
}

