  field(ONAM, "1")
  field(SCAN, "Passive")
  field(VAL, "1")
  field(OUT, "$(s):$(ta):Skf$(hexa):ProcDistReqBusy PP")
}

record(busy, "$(s):$(ta):Skf$(hexa):ProcDistReqBusy") {
  field(SCAN, "Passive")
}

# use this PV for the control PV to the ProcDistReq sequencer.
record(calc, "$(s):$(ta):Skf$(hexa):ProcDistSet") {
  field(INPA, "$(dp) CPP")	# detector position readback
  field(EGU, "m")
  field(MDEL, "-1.0")
  field(CALC, "A/1000.0")
  info(autosaveFields, "VAL")
  info(archive, "Monitor, 00:00:10, VAL")
}

################

record(ao, "$(s):$(ta):Skf$(hexa):InitWvlenSet") {
  field(EGU, "A")
  field(SCAN, "Passive")
  field(MDEL, "-1.0")
  info(autosaveFields, "VAL")
}

record(ao, "$(s):$(ta):Skf$(hexa):MCMaxWvlenSet") {
  field(EGU, "A")
  field(SCAN, "Passive")
  field(MDEL, "-1.0")
  info(autosaveFields, "VAL")
}

record(aSub, "$(s):$(ta):Skf$(hexa):CalcPhases") {
   field(SNAM, "calc6Phases")
   field(INPA, "$(s):$(ta):Skf$(hexa):InitWvlenSet CPP")
   field(INPB, "$(s):$(ta):Skf$(hexa):ProcDistSet CPP")
   field(INPC, "$(s):$(ta):Skf$(hexa):SpeedReq CPP")
   field(FTC, "LONG")
   field(INPD, "$(s):$(ta):Skf$(hexa):DistModSamp")
   field(INPE, "$(s):$(ta):Skf$(hexa):MCON")
   field(FTE, "SHORT")
   field(INPF, "$(s):$(ta):Skf$(hexa):MCMaxWvlenSet CPP")
   field(OUTA, "$(s):$(ta):Skf1:TotalDelaySet PP")
   field(OUTB, "$(s):$(ta):Skf2:TotalDelaySet PP")
   field(OUTC, "$(s):$(ta):Skf3:TotalDelaySet PP")
   field(OUTD, "$(s):$(ta):Skf4:TotalDelaySet PP")
   field(OUTE, "$(s):$(ta):Skf5:TotalDelaySet PP")
   field(OUTF, "$(s):$(ta):Skf6:TotalDelaySet PP")
   
}

record(aSub, "$(s):$(ta):Skf$(hexa):CalcBandwidth") {
   field(SNAM, "calc6Wavelengths")
   field(INPA, "$(s):$(ta):Skf1:SpeedSet CPP")
   field(FTA, "SHORT")
   field(INPB, "$(s):$(ta):Skf1:TotalDelaySet CPP")
   field(INPC, "$(s):$(ta):Skf2:TotalDelaySet CPP")
   field(INPD, "$(s):$(ta):Skf3:TotalDelaySet CPP")
   field(INPE, "$(s):$(ta):Skf4:TotalDelaySet CPP")
   field(INPF, "$(s):$(ta):Skf5:TotalDelaySet CPP")
   field(INPG, "$(s):$(ta):Skf6:TotalDelaySet CPP")
   field(OUTA, "$(s):$(ta):Skf$(hexa):MinWvlen1 PP")
   field(OUTB, "$(s):$(ta):Skf$(hexa):MaxWvlen1 PP")
   field(OUTC, "$(s):$(ta):Skf$(hexa):MinWvlen2 PP")
   field(OUTD, "$(s):$(ta):Skf$(hexa):MaxWvlen2 PP")
}

record(ai, "$(s):$(ta):Skf$(hexa):MinWvlen1") {
   field(EGU, "A")
}
record(ai, "$(s):$(ta):Skf$(hexa):MaxWvlen1") {
   field(EGU, "A")
}
record(ai, "$(s):$(ta):Skf$(hexa):MinWvlen2") {
   field(EGU, "A")
}
record(ai, "$(s):$(ta):Skf$(hexa):MaxWvlen2") {
   field(EGU, "A")
}

