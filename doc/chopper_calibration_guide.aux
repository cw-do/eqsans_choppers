\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces hexaSub OGC Phases for Monochromatic Mode (10\,\r A{} $\pm $ 10\%, SDD=4\,m)\relax }}{5}{table.caption.5}\protected@file@percent }
\newlabel{tab:mono_phases}{{2}{5}{hexaSub OGC Phases for Monochromatic Mode (10\,\AA {} $\pm $ 10\%, SDD=4\,m)\relax }{table.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Distance--time diagram for monochromatic mode: 10\,\r A{} $\pm $ 10\% (9.5--10.5\,\r A{}). All six choppers are active with phases calculated by hexaSub. The ``a'' choppers define the lower wavelength cutoff while ``b'' choppers define the upper cutoff, creating a precisely bounded wavelength band.\relax }}{6}{figure.caption.6}\protected@file@percent }
\newlabel{fig:diagram_mono}{{3}{6}{Distance--time diagram for monochromatic mode: 10\,\AA {} $\pm $ 10\% (9.5--10.5\,\AA {}). All six choppers are active with phases calculated by hexaSub. The ``a'' choppers define the lower wavelength cutoff while ``b'' choppers define the upper cutoff, creating a precisely bounded wavelength band.\relax }{figure.caption.6}{}}
