\@writefile{toc}{\contentsline {subsection}{\numberline {2.3}60\,Hz vs 30\,Hz Operation}{4}{subsection.2.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Distance--time diagram for 60\,Hz mode (2.5--6.1\,\r A{} band). Shaded rectangles indicate chopper closed periods. Blue trajectories show neutrons that successfully pass through all four choppers (1b, 2b, 3a, 3b). The choppers define a single wavelength band per source pulse.\relax }}{4}{figure.caption.3}\protected@file@percent }
\newlabel{fig:diagram_60hz}{{1}{4}{Distance--time diagram for 60\,Hz mode (2.5--6.1\,\AA {} band). Shaded rectangles indicate chopper closed periods. Blue trajectories show neutrons that successfully pass through all four choppers (1b, 2b, 3a, 3b). The choppers define a single wavelength band per source pulse.\relax }{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Distance--time diagram for 30\,Hz frame-skip mode. Two distinct wavelength bands are visible: Band\nobreakspace  {}1 (2.5--6.1\,\r A{}) from the current pulse, and Band\nobreakspace  {}2 (9.8--13.4\,\r A{}) from the previous pulse. The choppers 1b and 3a align to the previous pulse while 2b and 3b align to the current pulse, creating the characteristic dual-band pattern.\relax }}{5}{figure.caption.4}\protected@file@percent }
\newlabel{fig:diagram_30hz}{{2}{5}{Distance--time diagram for 30\,Hz frame-skip mode. Two distinct wavelength bands are visible: Band~1 (2.5--6.1\,\AA {}) from the current pulse, and Band~2 (9.8--13.4\,\AA {}) from the previous pulse. The choppers 1b and 3a align to the previous pulse while 2b and 3b align to the current pulse, creating the characteristic dual-band pattern.\relax }{figure.caption.4}{}}
